# Gemini API Key (구글 AI 에이전트 연동용)
GEMINI_API_KEY=your_gemini_api_key_here

# 한국투자증권 API 설정 (모의투자 및 실전투자용)
# KIS: Korea Investment & Securities
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here
KIS_CANO=your_account_number_here  # 종합계좌번호 (8자리)
KIS_ACNT_PRDT_CD=01               # 계좌상품코드 (보통 01)
KIS_URL=https://openapimts.koreainvestment.com:29443  # 모의투자용 URL (실전투자는 https://openapi.koreainvestment.com:10443)

# 구글 스프레드시트 보안 연동 설정
GOOGLE_SHEET_CREDENTIALS_PATH=path_to_your_service_account_credentials.json  # 서비스 계정 인증키 파일 경로
GOOGLE_SHEET_KEY=your_spreadsheet_key_here                                 # 구글 스프레드시트 고유 키값
